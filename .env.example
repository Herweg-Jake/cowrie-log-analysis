# Elasticsearch connection settings
ES_HOST=http://192.168.3.x:9200
ES_USER=
ES_PASSWORD=
ES_INDEX_PREFIX=cowrie-sessions

# Data paths
HONEYPOT_DATA_DIR=/opt/honeypot
GEOLITE_DB_PATH=/path/to/GeoLite2-City.mmdb

# Processing settings
BULK_SIZE=500
LOCATIONS=ssh-amsterdam,ssh-bangalore,ssh-london,ssh-ny,ssh-singapore,ssh-toronto

# LLM Agent settings (for session analysis)
# Option 1: Google AI Studio (free tier - strict rate limits)
GOOGLE_API_KEY=your-api-key-from-aistudio.google.com

# Option 2: Google Cloud Vertex AI (uses $300 credits)
# Set GOOGLE_CLOUD_PROJECT to use Vertex AI instead of AI Studio
# Requires: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1  # optional, defaults to us-central1
